# Public because the static-export site fetches it directly from the browser.
# It's a form-submission endpoint, not a secret credential.
# See docs/google-apps-script/SETUP.md for how to get this URL.
NEXT_PUBLIC_CONSULTATION_ENDPOINT=

# Used for sitemap.xml / robots.txt / canonical URLs. Set to the real
# Vercel preview URL first, then the final production domain later.
NEXT_PUBLIC_SITE_URL=https://tiff-website.vercel.app
